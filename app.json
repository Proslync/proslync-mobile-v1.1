{
  "expo": {
    "name": "status",
    "slug": "status",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "status",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.statusdigitalinc.status",
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.statusdigitalinc.status"
        ],
        "com.apple.developer.proximity-reader.payment.acceptance": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Status uses your location to show nearby events and share your live location with friends",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Status uses your location to keep your location on the map updated, even when the app is closed",
        "NSCameraUsageDescription": "Status needs camera access for video calls and scanning IDs",
        "NSMicrophoneUsageDescription": "Status needs microphone access for voice and video calls",
        "UIBackgroundModes": [
          "location",
          "voip"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.statusdigitalinc.status"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Status uses your location to keep your location on the map updated, even when the app is closed",
          "locationWhenInUsePermission": "Status uses your location to show nearby events and share your live location with friends",
          "isBackgroundLocationEnabled": true
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.15.2"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Status needs camera access to scan IDs and membership cards",
          "enableCodeScanner": true
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.statusdigitalinc.status",
          "enableGooglePay": true
        }
      ],
      [
        "@stripe/stripe-terminal-react-native",
{
          "tapToPayCheck": true
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "@stream-io/video-react-native-sdk",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Status needs camera access for video calls and scanning IDs",
          "microphonePermission": "Status needs microphone access for voice and video calls"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b70b86f6-b123-4736-840a-5a427656be43"
      }
    }
  }
}
