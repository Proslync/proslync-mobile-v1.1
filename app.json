{
  "expo": {
    "name": "status",
    "slug": "status",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "status",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.statusdigitalinc.status",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Status needs your location to show events near you",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Status needs your location to show events near you",
        "NSCameraUsageDescription": "Status needs camera access to scan IDs and membership cards"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.statusdigitalinc.status"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.15.2"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Status needs camera access to scan IDs and membership cards",
          "enableCodeScanner": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b70b86f6-b123-4736-840a-5a427656be43"
      }
    }
  }
}
