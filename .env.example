# API Configuration
EXPO_PUBLIC_API_URL=https://your-api-url.com
EXPO_PUBLIC_WS_URL=wss://your-api-url.com

# Stripe Publishable Key (get from Stripe Dashboard)
# Use pk_test_* for development, pk_live_* for production
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stream Chat API Key (get from Stream Dashboard)
EXPO_PUBLIC_STREAM_API_KEY=your_stream_api_key

# Mapbox Access Token
# Get yours at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Note: For iOS builds, you also need MAPBOX_DOWNLOAD_TOKEN
# Set it in your ~/.netrc file or EAS secrets
